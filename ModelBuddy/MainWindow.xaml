<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ModelBuddy.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModelBuddy"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Model Buddy">

    <Grid Loaded="RootGrid_Loaded">
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" VerticalAlignment="Top" Height="48">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="16,0,0,0" VerticalAlignment="Center">
                <Image Source="/Assets/ModelBuddy32.png" Width="20" Height="20"/>
                <TextBlock Text="Model Buddy" Style="{StaticResource CaptionTextBlockStyle}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Main Content -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="True"
            PaneDisplayMode="Left"
            IsPaneToggleButtonVisible="True"
            SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Chat" Tag="Chat">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BD;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Models" Tag="Models" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Logs" Tag="Logs">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7BA;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame"/>
        </NavigationView>

        <!-- Status Bar -->
        <Border 
            Grid.Row="2" 
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0"
            Padding="16,8">
            <Grid DataContext="{x:Bind ViewModel}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Connection Status -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse 
                        x:Name="ConnectionIndicator"
                        Width="10" Height="10"
                        Fill="{Binding IsConnected, Converter={StaticResource ConnectionToBrushConverter}}"/>
                    <TextBlock 
                        Text="{Binding ConnectionStatus}" 
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        VerticalAlignment="Center"/>
                    <HyperlinkButton 
                        Content="Reconnect"
                        Command="{Binding ReconnectCommand}"
                        FontSize="12"
                        Padding="4,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding CanReconnect, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock 
                        Text="·"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        VerticalAlignment="Center"
                        Visibility="{Binding CanReconnect, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <HyperlinkButton 
                        Content="Get started with Foundry Local"
                        NavigateUri="https://learn.microsoft.com/azure/foundry-local/get-started"
                        FontSize="12"
                        Padding="4,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding CanReconnect, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <ProgressRing 
                        IsActive="{Binding IsConnecting}"
                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVisibilityConverter}}"
                        Width="14" Height="14"/>
                </StackPanel>

                <!-- Endpoint -->
                <TextBlock 
                    Grid.Column="1" 
                    Text="{Binding Endpoint}" 
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    VerticalAlignment="Center"
                    Margin="16,0,0,0"
                    Visibility="{Binding Endpoint, Converter={StaticResource StringVisibilityConverter}}"/>

                <!-- Selected Model -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock 
                        Text="Chat Model:" 
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        VerticalAlignment="Center"/>
                    <Border 
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="4"
                        Padding="8,2"
                        Visibility="{Binding SelectedChatModel, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock 
                            Text="{Binding SelectedChatModel.DisplayName}" 
                            FontSize="12"
                            Foreground="White"
                            VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock 
                        Text="None selected" 
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        VerticalAlignment="Center"
                        Visibility="{Binding SelectedChatModel, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=True}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
