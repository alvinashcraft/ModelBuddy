<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModelBuddy.Views.ChatPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ModelBuddy.Views"
    xmlns:models="using:ModelBuddy.Models"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header with model selector -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <FontIcon Glyph="&#xE8BD;" FontSize="28"/>
                <TextBlock Text="Chat" Style="{StaticResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
                <!-- Loading indicator -->
                <ProgressRing 
                    IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                    Width="20" Height="20"
                    VerticalAlignment="Center"/>
                <!-- Connection status -->
                <Border 
                    CornerRadius="4" 
                    Padding="8,4" 
                    VerticalAlignment="Center"
                    Background="{x:Bind local:ChatPage.GetConnectionBackground(ViewModel.IsConnected), Mode=OneWay}"
                    Visibility="{x:Bind local:ChatPage.GetConnectionVisibility(ViewModel.StatusMessage), Mode=OneWay}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock 
                            Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" 
                            FontSize="12"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <HyperlinkButton 
                            Content="Reconnect"
                            Command="{x:Bind ViewModel.InitializeCommand}"
                            FontSize="12"
                            Padding="0"
                            VerticalAlignment="Center"
                            Visibility="{x:Bind local:ChatPage.GetReconnectVisibility(ViewModel.IsConnected, ViewModel.IsLoading), Mode=OneWay}"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ComboBox 
                    x:Name="ModelSelector"
                    ItemsSource="{x:Bind ViewModel.AvailableModels, Mode=OneWay}"
                    SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName"
                    Width="220"
                    PlaceholderText="Select a model"
                    IsEnabled="{x:Bind ViewModel.IsConnected, Mode=OneWay}"
                    VerticalAlignment="Center"/>
                <Button 
                    Command="{x:Bind ViewModel.ClearChatCommand}" 
                    ToolTipService.ToolTip="Clear Chat"
                    VerticalAlignment="Center"
                    Padding="10,8">
                    <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Chat messages -->
        <ScrollViewer 
            x:Name="ChatScroller"
            Grid.Row="1"
            VerticalScrollBarVisibility="Auto">
            <ItemsControl 
                x:Name="MessagesList"
                ItemsSource="{x:Bind ViewModel.Messages, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ChatMessage">
                        <Grid Margin="0,8">
                            <!-- User message (right aligned) -->
                            <Border 
                                HorizontalAlignment="Right"
                                MaxWidth="600"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="12,12,4,12"
                                Padding="16,12"
                                Visibility="{x:Bind local:ChatPage.GetUserVisibility((models:ChatMessage))}">
                                <TextBlock 
                                    Text="{x:Bind Content}" 
                                    TextWrapping="Wrap"
                                    Foreground="White"/>
                            </Border>

                            <!-- Assistant message (left aligned) -->
                            <Border 
                                HorizontalAlignment="Left"
                                MaxWidth="600"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="12,12,12,4"
                                Padding="16,12"
                                Visibility="{x:Bind local:ChatPage.GetAssistantVisibility((models:ChatMessage))}">
                                <controls:MarkdownTextBlock 
                                    Text="{x:Bind Content}"
                                    Background="Transparent"/>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Empty state -->
        <StackPanel 
            Grid.Row="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="12"
            Visibility="{x:Bind local:ChatPage.IsEmpty(ViewModel.Messages.Count), Mode=OneWay}">
            <FontIcon Glyph="&#xE8BD;" FontSize="48" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock 
                Text="Start a conversation" 
                Style="{StaticResource SubtitleTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            <TextBlock 
                Text="Select a model and type a message to begin chatting."
                Style="{StaticResource BodyTextBlockStyle}"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
        </StackPanel>

        <!-- Input area -->
        <Grid Grid.Row="2" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox 
                x:Name="MessageInput"
                Text="{x:Bind ViewModel.UserInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Type a message..."
                AcceptsReturn="False"
                TextWrapping="Wrap"
                MaxHeight="120">
                <TextBox.KeyboardAccelerators>
                    <KeyboardAccelerator Key="Enter" Modifiers="None" Invoked="SendAccelerator_Invoked"/>
                </TextBox.KeyboardAccelerators>
            </TextBox>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button 
                    Command="{x:Bind ViewModel.SendMessageCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Send">
                    <FontIcon Glyph="&#xE724;" FontSize="16"/>
                </Button>
                <Button 
                    Command="{x:Bind ViewModel.StopGenerationCommand}"
                    ToolTipService.ToolTip="Stop">
                    <FontIcon Glyph="&#xE71A;" FontSize="16"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Generating indicator -->
        <ProgressBar 
            Grid.Row="2"
            VerticalAlignment="Top"
            Margin="0,-8,0,0"
            IsIndeterminate="{x:Bind ViewModel.IsGenerating, Mode=OneWay}"
            Visibility="{x:Bind ViewModel.IsGenerating, Mode=OneWay}"/>
    </Grid>
</Page>
