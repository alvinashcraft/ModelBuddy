<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="ModelBuddy.Views.ModelsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ModelBuddy.Views"
    xmlns:models="using:ModelBuddy.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Loaded="Page_Loaded">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
            <FontIcon Glyph="&#xE8F1;" FontSize="28"/>
            <TextBlock Text="Model Management" Style="{StaticResource TitleTextBlockStyle}"/>
        </StackPanel>

        <!-- Toolbar -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Search Box -->
            <TextBox 
                Grid.Column="0"
                PlaceholderText="Search models..."
                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                MaxWidth="300"
                HorizontalAlignment="Left"/>

            <!-- Action Buttons -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                <Button 
                    Command="{x:Bind ViewModel.SelectForChatCommand}"
                    ToolTipService.ToolTip="Select this model for chat">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE8BD;" FontSize="16"/>
                        <TextBlock Text="Use for Chat"/>
                    </StackPanel>
                </Button>
                <Button 
                    Command="{x:Bind ViewModel.DownloadModelCommand}"
                    Style="{StaticResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE896;" FontSize="16"/>
                        <TextBlock Text="Download"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.DeleteModelCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                        <TextBlock Text="Delete"/>
                    </StackPanel>
                </Button>
                <Button Command="{x:Bind ViewModel.RefreshCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="&#xE72C;" FontSize="16"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Models List -->
        <ListView 
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Models}"
            SelectedItem="{x:Bind ViewModel.SelectedModel, Mode=TwoWay}"
            SelectionMode="Single">
            <ListView.Header>
                <Grid Padding="12,8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="4" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Model" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Status" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="3" Text="Est. RAM" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="4" Text="Can Run" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="5" Text="Device" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="6" Text="Max Tokens" FontWeight="SemiBold"/>
                </Grid>
            </ListView.Header>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:LocalModel">
                    <Grid Padding="12,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <!-- Model Info -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold"/>
                            <TextBlock Text="{x:Bind Provider}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"/>
                            <Border Background="{ThemeResource AccentFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" Margin="0,4,0,0">
                                <TextBlock Text="{x:Bind Task}" FontSize="11" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <!-- Status -->
                        <Border Grid.Column="1" 
                                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}" 
                                CornerRadius="4" 
                                Padding="8,4"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind Status}" FontSize="12"/>
                        </Border>

                        <!-- Size -->
                        <TextBlock Grid.Column="2" Text="{x:Bind FormattedSize}" VerticalAlignment="Center"/>

                        <!-- Est. RAM -->
                        <TextBlock Grid.Column="3" Text="{x:Bind FormattedEstimatedRam}" VerticalAlignment="Center"/>

                        <!-- Can Run -->
                        <Border Grid.Column="4" 
                                Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" 
                                CornerRadius="4" 
                                Padding="6,2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind CanRun}">
                            <TextBlock Text="Yes" FontSize="11"/>
                        </Border>

                        <!-- Device -->
                        <TextBlock Grid.Column="5" Text="{x:Bind Device}" VerticalAlignment="Center"/>

                        <!-- Max Tokens -->
                        <TextBlock Grid.Column="6" Text="{x:Bind MaxTokens}" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status Bar with Progress -->
        <StackPanel Grid.Row="3" Margin="0,16,0,0" Spacing="8">
            <!-- Progress Bar (shown only when downloading) -->
            <ProgressBar 
                Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsLoading}"
                Height="4"/>
            
            <!-- Status Message -->
            <TextBlock 
                Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                FontSize="12"
                TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>
